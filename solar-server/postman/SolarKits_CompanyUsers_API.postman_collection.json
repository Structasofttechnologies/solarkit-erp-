{
  "info": {
    "_postman_id": "solarkits-company-users-v2",
    "name": "SolarKits - Company Users API",
    "description": "Complete API collection for Company User management and Mobile Login.\n\n🔑 HOW TO USE:\n1. Set 'base_url' variable to your server URL (default: http://localhost:5000/api)\n2. Run 'Admin Login' to get admin token\n3. Use 'Create Company User' to create a new user\n4. Run 'Mobile Login' — only mobile number needed, NO password\n5. The returned token can be used in 'Get My Profile (Mobile)'",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api",
      "type": "string",
      "description": "Base API URL. Change to your production URL when deploying."
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string",
      "description": "Admin JWT token. Auto-filled after running 'Admin Login'."
    },
    {
      "key": "company_user_token",
      "value": "",
      "type": "string",
      "description": "Company User JWT token. Auto-filled after running 'Mobile Login'."
    },
    {
      "key": "company_user_id",
      "value": "",
      "type": "string",
      "description": "Company User _id. Auto-filled after running 'Create Company User'."
    }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('admin_token', res.token);",
                  "  console.log('✅ Admin token saved!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@solarkits.com\",\n  \"password\": \"admin123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Login as admin to get JWT token. Replace email/password with your admin credentials."
          }
        }
      ]
    },
    {
      "name": "👤 Company Users (Admin)",
      "item": [
        {
          "name": "Create Company User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data._id) {",
                  "  pm.collectionVariables.set('company_user_id', res.data._id);",
                  "  console.log('✅ Company User ID saved:', res.data._id);",
                  "  console.log('📱 Login with mobile number:', res.data.mobileNumber);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Rahul Sharma\",\n  \"mobileNumber\": \"9876543210\",\n  \"emailAddress\": \"rahul.sharma@example.com\",\n  \"district\": \"Pune\",\n\n  \"partnerGoalsEnabled\": true,\n  \"partnerMonthlyTargetKw\": 50,\n  \"partnerPerKwCommission\": 500,\n  \"partnerQuotePermissions\": {\n    \"create\": true,\n    \"edit\": false,\n    \"delete\": false\n  },\n  \"partnerTypes\": [\n    {\n      \"type\": \"Channel Partner\",\n      \"count\": 5,\n      \"deadline\": \"2026-12-31\"\n    }\n  ],\n\n  \"projectGoalEnabled\": true,\n  \"projectMonthlyTargetKw\": 100,\n  \"projectPerKwCommission\": 800,\n  \"projectTypes\": [\n    {\n      \"type\": \"Residential 3 to 10 kw\",\n      \"count\": 10,\n      \"deadline\": \"2026-12-31\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/company-users",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "company-users"
              ]
            },
            "description": "Creates a new company user.\n\n📱 After creation, user can log in to the mobile app using ONLY their mobile number — no password required."
          },
          "response": [
            {
              "name": "201 - User Created",
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"message\": \"Company user created successfully. User can now log in with their mobile number.\",\n  \"data\": {\n    \"_id\": \"685abc123456789\",\n    \"fullName\": \"Rahul Sharma\",\n    \"mobileNumber\": \"9876543210\",\n    \"emailAddress\": \"rahul.sharma@example.com\",\n    \"district\": \"Pune\",\n    \"role\": \"company_user\",\n    \"status\": \"active\",\n    \"createdAt\": \"2026-06-02T07:00:00.000Z\"\n  }\n}"
            },
            {
              "name": "400 - Duplicate Mobile",
              "status": "Bad Request",
              "code": 400,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": false,\n  \"message\": \"A company user with this mobile number already exists.\"\n}"
            }
          ]
        },
        {
          "name": "Get All Company Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/company-users",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "company-users"
              ]
            },
            "description": "Returns a list of all company users."
          }
        },
        {
          "name": "Get Company User by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/company-users/{{company_user_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "company-users",
                "{{company_user_id}}"
              ]
            }
          }
        },
        {
          "name": "Update Company User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Rahul Sharma Updated\",\n  \"district\": \"Mumbai\",\n  \"status\": \"active\",\n  \"partnerGoalsEnabled\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/company-users/{{company_user_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "company-users",
                "{{company_user_id}}"
              ]
            }
          }
        },
        {
          "name": "Delete Company User",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/company-users/{{company_user_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "company-users",
                "{{company_user_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "📱 Mobile App Login",
      "item": [
        {
          "name": "Mobile Login (Mobile Number Only — No Password)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.token) {",
                  "  pm.collectionVariables.set('company_user_token', res.token);",
                  "  console.log('✅ Company User token saved!');",
                  "  console.log('👤 Logged in as:', res.user.fullName);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobileNumber\": \"9876543210\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/company-users/mobile-login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "company-users",
                "mobile-login"
              ]
            },
            "description": "📱 Mobile App Login — NO PASSWORD REQUIRED.\n\nJust send the mobileNumber. If the user exists and is active, a JWT token is returned.\n\nThis endpoint is PUBLIC — no admin token needed."
          },
          "response": [
            {
              "name": "200 - Login Success",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"message\": \"Login successful.\",\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"_id\": \"685abc123456789\",\n    \"fullName\": \"Rahul Sharma\",\n    \"mobileNumber\": \"9876543210\",\n    \"emailAddress\": \"rahul.sharma@example.com\",\n    \"district\": \"Pune\",\n    \"role\": \"company_user\",\n    \"status\": \"active\",\n    \"partnerGoalsEnabled\": true,\n    \"partnerMonthlyTargetKw\": 50,\n    \"partnerPerKwCommission\": 500,\n    \"partnerQuotePermissions\": {\n      \"create\": true,\n      \"edit\": false,\n      \"delete\": false\n    },\n    \"partnerTypes\": [\n      {\n        \"type\": \"Channel Partner\",\n        \"count\": 5,\n        \"deadline\": \"2026-12-31T00:00:00.000Z\"\n      }\n    ],\n    \"projectGoalEnabled\": false\n  }\n}"
            },
            {
              "name": "401 - Mobile Not Found",
              "status": "Unauthorized",
              "code": 401,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": false,\n  \"message\": \"No account found with this mobile number. Please contact your administrator.\"\n}"
            },
            {
              "name": "403 - Account Inactive",
              "status": "Forbidden",
              "code": 403,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": false,\n  \"message\": \"Your account is inactive. Please contact the administrator.\"\n}"
            }
          ]
        },
        {
          "name": "Get My Profile (Mobile)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{company_user_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/company-users/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "company-users",
                "me"
              ]
            },
            "description": "Get the profile of the currently logged-in company user.\nRequires company_user_token from 'Mobile Login' — NOT the admin token."
          },
          "response": [
            {
              "name": "200 - My Profile",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"_id\": \"685abc123456789\",\n    \"fullName\": \"Rahul Sharma\",\n    \"mobileNumber\": \"9876543210\",\n    \"role\": \"company_user\",\n    \"status\": \"active\"\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "🏥 Health Check",
      "item": [
        {
          "name": "Server Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        }
      ]
    }
  ]
}