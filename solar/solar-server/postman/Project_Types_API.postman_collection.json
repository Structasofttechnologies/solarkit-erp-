    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": "your_jwt_token_here"
    },
    {
      "key": "categoryId",
      "value": "replace_with_parent_category_id"
    },
    {
      "key": "subCategoryId",
      "value": "replace_with_parent_sub_category_id"
    },
    {
      "key": "projectTypeId",
      "value": "replace_with_parent_project_type_id"
    }
  ]
}
