{
  "info": {
    "name": "Product Settings API (Categories -> Project Types)",
    "description": "API endpoints for Categories, Sub Categories, Project Types, and Sub Project Types.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/masters/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "masters", "categories"]
            }
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Solar Panels\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/masters/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "masters", "categories"]
            }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Solar Panels Updated\",\n    \"status\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/masters/categories/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "masters", "categories", ":id"],
              "variable": [{ "key": "id", "value": "replace_with_category_id" }]
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/masters/categories/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "masters", "categories", ":id"],
              "variable": [{ "key": "id", "value": "replace_with_category_id" }]
            }
          }
        }
      ]
    },
    {
      "name": "2. Sub Categories",
      "item": [
        {
          "name": "Get Sub Categories by Category ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/masters/sub-categories?categoryId={{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "masters", "sub-categories"],
              "query": [
                { "key": "categoryId", "value": "{{categoryId}}" }
              ]
            }
          }
        },
        {
          "name": "Create Sub Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
